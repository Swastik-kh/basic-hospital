rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Allow read access to all collections for everyone (since this is a public hospital site)
    // You should restrict this if you want to make it private.
    match /{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
